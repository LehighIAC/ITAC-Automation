{
  // Recommendation No., integer
  REC: 1,
  // hours per day, float (allows half hours)
  HR: 24.0,
  // days per week, float (allows half day on weekends)
  DY: 2.0,
  // weeks per year, int
  WK: 52,
  // Current compressor operating pressure, psi, integer
  CCP: 115,
  // Recommended compressor operating pressure, psi, integer
  RCP: 95,
  // Pressure requirement, psi, integer
  REQ: 80,
  // Number of stages, integer, default 1
  N: 1,
  // Horsepower of compressors, HP, integer
  HP: 40,
  // Load Factor, %, integer
  LF: 15,
  // Efficiency of compressor, %, integer
  ETA: 85,
  // Coincidence factor, %, integer, default 100
  CF: 100,
  // implementation cost, $, integer
  IC: 0,
}
