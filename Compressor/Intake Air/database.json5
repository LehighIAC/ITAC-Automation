{
  // Recommendation No., integer
  REC: 5,
  // ZIP code for average outdoor temperature, ZIP, string
  ZIP: "17084",
  // hours per day, float (allows half hours)
  HR: 24.0,
  // days per week, float (allows half day on weekends)
  DY: 7.0,
  // weeks per year, int
  WK: 52,
  // Total Horsepower of compressors, HP, integer
  HP: 450,
  // Average difference in indoor temperature vs outside temperature, degrees F, integer
  DT: 13,
  // Average daily indoor temperature, degrees F, integer
  TI: 75,
  // Load Factor, %, integer
  LF: 75,
  // Control Type, int
  // 1: Blow Off
  // 2: Modulation
  // 3: Load/Unload
  // 4: VFD
  CT: 3,
  // Efficiency of compressor, %, integer
  ETA: 85,
  // Coincidence Factor, %, integer
  CF: 100,
  // Implementation Cost, $, integer
  IC: 4000,
}
